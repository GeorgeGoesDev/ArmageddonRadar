{
  "expo": {
    "name": "ArmageddonRadar",
    "slug": "ArmageddonRadar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0C10",
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#66FCF1"
        }
      ],
      "expo-image",
      "expo-sharing",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Armageddon Radar to save NASA images to your gallery.",
          "savePhotosPermission": "Allow Armageddon Radar to save NASA images to your gallery."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.georgegoesdev.armageddonradar"
    },
    "android": {
      "package": "com.georgegoesdev.armageddonradar",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-foreground.png",
        "backgroundColor": "#0B0C10"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
